@model IEnumerable<FlashFood.Web.Models.Entities.Product>
@using FlashFood.Web.Models.Entities
@{
    ViewData["Title"] = "Quản lý sản phẩm";

    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
    var currentCategoryId = ViewBag.CurrentCategoryId as int?;
}
<section class="max-w-7xl mx-auto px-4 md:px-10 py-8">
    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-100 hover:bg-slate-200 text-sm font-semibold mb-4">
        <span class="material-symbols-outlined">arrow_back</span>
        Về màn hình quản trị
    </a>

    <div class="flex justify-between items-center mb-6">
        <h1 class="text-3xl font-black">Quản lý sản phẩm</h1>
        <a asp-area="Admin" asp-controller="Products" asp-action="Create" class="px-4 py-2 rounded-xl bg-primary text-white">Thêm món</a>
    </div>

    <div class="bg-white border rounded-2xl p-4 mb-6">
        <p class="text-sm text-slate-500 mb-3">Chọn danh mục để xem riêng:</p>
        <div class="flex flex-wrap gap-2">
            <a asp-area="Admin" asp-controller="Products" asp-action="Index"
               class="px-3 py-2 rounded-xl text-sm font-semibold @(currentCategoryId == null ? "bg-primary text-white" : "bg-slate-100 text-slate-700 hover:bg-slate-200")">
                Tất cả
            </a>

            @foreach (var category in categories)
            {
                <a asp-area="Admin" asp-controller="Products" asp-action="Index" asp-route-categoryId="@category.Id"
                   class="px-3 py-2 rounded-xl text-sm font-semibold @(currentCategoryId == category.Id ? "bg-primary text-white" : "bg-slate-100 text-slate-700 hover:bg-slate-200")">
                    @category.Name
                </a>
            }
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="bg-white border rounded-xl p-4 text-slate-500">Không có sản phẩm trong danh mục này.</div>
    }
    else
    {
        <div class="space-y-3">
            @foreach (var item in Model)
            {
                <div class="bg-white border rounded-xl p-3 flex justify-between items-center gap-3">
                    <div class="flex items-center gap-3">
                        <img src="@item.ImageUrl" alt="@item.Name" class="w-16 h-16 rounded-lg object-cover border" />
                        <div>
                            <strong>@item.Name</strong>
                            <p class="text-sm text-slate-500">@item.Category?.Name - @item.BasePrice.ToString("N0")đ</p>
                        </div>
                    </div>
                    <div class="flex gap-2">
                        <a asp-area="Admin" asp-controller="Products" asp-action="Edit" asp-route-id="@item.Id" class="px-3 py-2 bg-slate-100 rounded-lg">Sửa</a>
                        <form asp-area="Admin" asp-controller="Products" asp-action="Delete" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <input type="hidden" name="returnCategoryId" value="@currentCategoryId" />
                            <button class="px-3 py-2 bg-red-100 text-red-700 rounded-lg">Xóa</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</section>

@model IEnumerable<FlashFood.Web.Models.Entities.Product>
@using FlashFood.Web.Models.ViewModels
@{
    string NormalizeCategoryName(string? input)
    {
        var value = (input ?? string.Empty).Trim().ToLowerInvariant().Normalize(System.Text.NormalizationForm.FormD);
        var sb = new System.Text.StringBuilder();

        foreach (var ch in value)
        {
            var unicodeCategory = System.Globalization.CharUnicodeInfo.GetUnicodeCategory(ch);
            if (unicodeCategory != System.Globalization.UnicodeCategory.NonSpacingMark)
            {
                sb.Append(ch);
            }
        }

        return sb.ToString().Normalize(System.Text.NormalizationForm.FormC);
    }

    ViewData["Title"] = "Thực đơn";
    var categories = ViewBag.Categories as List<FlashFood.Web.Models.Entities.Category> ?? new();
    var filter = ViewBag.Filter as ProductFilterViewModel ?? new();
}
<section class="px-4 py-6 md:px-10">
    <div class="max-w-7xl mx-auto">
        <div class="relative overflow-hidden rounded-3xl bg-slate-900 aspect-[21/9]">
            <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/40 to-transparent z-10"></div>
            <img class="absolute inset-0 w-full h-full object-cover" src="https://images.unsplash.com/photo-1550547660-d9450f859349?w=1600" alt="Flash Food Hero" />
            <div class="relative z-20 h-full flex flex-col justify-center px-8 md:px-16 max-w-2xl gap-4">
                <span class="inline-block px-4 py-1 bg-secondary text-slate-900 font-bold text-xs uppercase rounded-full w-max">Giao hàng nhanh</span>
                <h1 class="text-white text-4xl md:text-5xl font-black leading-tight">Nhanh chóng - Ngon miệng - <span class="text-primary">Flash Food!</span></h1>
                <p class="text-slate-200">Đặt món nhanh, giao tới tận nơi với trải nghiệm mượt mà trên mọi thiết bị.</p>
            </div>
        </div>
    </div>
</section>
<section class="max-w-7xl mx-auto px-4 md:px-10 py-2">
    <form method="get" class="grid md:grid-cols-4 gap-3 bg-white p-4 rounded-2xl border">
        <input name="SearchTerm" value="@filter.SearchTerm" placeholder="Tìm theo tên món" class="rounded-xl border px-3 py-2" />
        <select name="CategoryId" class="rounded-xl border px-3 py-2">
            <option value="">Tất cả danh mục</option>
            @foreach (var category in categories)
            {
                <option value="@category.Id" selected="@(filter.CategoryId == category.Id)">@category.Name</option>
            }
        </select>
        <select name="Sort" class="rounded-xl border px-3 py-2">
            <option value="newest" selected="@(filter.Sort == "newest")">Mới nhất</option>
            <option value="price_asc" selected="@(filter.Sort == "price_asc")">Giá tăng dần</option>
            <option value="price_desc" selected="@(filter.Sort == "price_desc")">Giá giảm dần</option>
        </select>
        <button class="bg-primary text-white rounded-xl font-semibold">Tìm kiếm</button>
    </form>
</section>
<section class="px-4 py-10 md:px-10 max-w-7xl mx-auto">
    <h2 class="text-2xl font-extrabold mb-8">Danh mục thực đơn</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        @foreach (var category in categories)
        {
            <a asp-action="Index" asp-route-CategoryId="@category.Id" class="cursor-pointer flex flex-col items-center gap-2 p-5 rounded-2xl bg-white border hover:border-primary/50 transition-all">
                @{
                    var normalizedName = NormalizeCategoryName(category.Name);
                }
                @if (!string.IsNullOrWhiteSpace(category.IconSvg))
                {
                    <span class="w-10 h-10 text-primary inline-flex items-center justify-center">@Html.Raw(category.IconSvg)</span>
                }
                else if (normalizedName.Contains("banh mi"))
                {
                    <span class="material-symbols-outlined text-5xl text-primary">bakery_dining</span>
                }
                else if (normalizedName.Contains("do uong") || normalizedName.Contains("uong"))
                {
                    <span class="material-symbols-outlined text-5xl text-primary">local_cafe</span>
                }
                else if (normalizedName.Contains("ga ran") || normalizedName.Contains("ga") || normalizedName.Contains("chicken"))
                {
                    <span class="material-symbols-outlined text-5xl text-primary">set_meal</span>
                }
                else if (normalizedName.Contains("mon phu") || normalizedName.Contains("phu") || normalizedName.Contains("side"))
                {
                    <span class="material-symbols-outlined text-5xl text-primary">restaurant</span>
                }
                else
                {
                    <span class="material-symbols-outlined text-5xl text-primary">restaurant</span>
                }
                <h3 class="font-bold">@category.Name</h3>
                <p class="text-slate-500 text-sm">@category.Description</p>
            </a>
        }
    </div>
</section>
<section class="px-4 pb-10 md:px-10 max-w-7xl mx-auto">
    <h2 class="text-2xl font-extrabold mb-6">Sản phẩm</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        @foreach (var item in Model)
        {
            var average = item.Reviews.Any() ? item.Reviews.Average(x => x.Rating) : 0;
            <div class="bg-white rounded-2xl overflow-hidden border hover:shadow-xl transition-all">
                <a asp-action="Details" asp-route-id="@item.Id"><img src="@item.ImageUrl" alt="@item.Name" class="w-full h-44 object-cover" /></a>
                <div class="p-4">
                    <div class="flex justify-between items-start gap-2">
                        <h3 class="font-extrabold text-base">@item.Name</h3>
                        <span class="text-primary font-bold text-sm">@item.BasePrice.ToString("N0")đ</span>
                    </div>
                    <p class="text-slate-500 text-sm mt-1 line-clamp-2">@item.Description</p>
                    <p class="text-yellow-500 text-sm mt-2">★ @average.ToString("0.0")</p>
                    <form asp-action="AddToCart" method="post" class="mt-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="productId" value="@item.Id" />
                        <button class="w-full py-2 bg-slate-100 hover:bg-primary hover:text-white rounded-xl font-semibold">Thêm vào giỏ</button>
                    </form>
                </div>
            </div>
        }
    </div>
</section>


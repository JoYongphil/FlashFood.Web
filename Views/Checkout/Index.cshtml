@using FlashFood.Web.Models.Entities
@model FlashFood.Web.Models.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Thanh toán";
    var vouchers = ViewBag.ActiveVouchers as List<Voucher> ?? new();
    var percentVouchers = vouchers.Where(x => x.Type == FlashFood.Web.Models.Enums.VoucherType.Percentage).ToList();
    var freeShipVouchers = vouchers.Where(x => x.Type == FlashFood.Web.Models.Enums.VoucherType.FreeShip).ToList();
}
<section class="max-w-4xl mx-auto px-4 md:px-10 py-8">
    <h1 class="text-3xl font-black mb-6">Thông tin thanh toán</h1>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="mb-6 bg-white border rounded-2xl p-4">
            <h2 class="text-xl font-bold mb-3">Voucher đang có</h2>
            @if (!vouchers.Any())
            {
                <p class="text-slate-500">Hiện chưa có voucher khả dụng.</p>
            }
            else
            {
                <div class="grid md:grid-cols-2 gap-3">
                    @foreach (var voucher in vouchers)
                    {
                        <div class="rounded-xl border p-3 bg-slate-50">
                            <p class="font-bold text-primary">@voucher.Code</p>
                            <p class="text-sm text-slate-600">
                                @(voucher.Type == FlashFood.Web.Models.Enums.VoucherType.Percentage
                                    ? $"Giảm {voucher.Value:0}%"
                                    : "Freeship toàn bộ")
                            </p>
                            <p class="text-xs text-slate-500">Hết hạn: @voucher.ExpiresAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                    }
                </div>
            }
        </div>
    }

    <form method="post" class="bg-white border rounded-2xl p-6 space-y-4">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="text-red-600"></div>
        <div class="grid md:grid-cols-2 gap-4">
            <input asp-for="CustomerName" placeholder="Họ tên" class="rounded-xl border px-3 py-2" />
            <input asp-for="Phone" placeholder="Số điện thoại" class="rounded-xl border px-3 py-2" />
            <input asp-for="Email" placeholder="Email" class="rounded-xl border px-3 py-2" />
            <input asp-for="Province" placeholder="Tỉnh/Thành" class="rounded-xl border px-3 py-2" />
            <input asp-for="District" placeholder="Quận/Huyện" class="rounded-xl border px-3 py-2" />
            <input asp-for="Ward" placeholder="Phường/Xã" class="rounded-xl border px-3 py-2" />
        </div>
        <input asp-for="AddressDetail" placeholder="Số nhà, tên đường" class="w-full rounded-xl border px-3 py-2" />
        <textarea asp-for="Note" placeholder="Ghi chú" class="w-full rounded-xl border px-3 py-2"></textarea>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="grid md:grid-cols-2 gap-4">
                <div>
                    <label asp-for="PercentVoucherCode" class="block text-sm font-semibold mb-1">Chọn voucher giảm giá</label>
                    <select asp-for="PercentVoucherCode" class="w-full rounded-xl border px-3 py-2">
                        <option value="">Không dùng voucher giảm giá</option>
                        @foreach (var voucher in percentVouchers)
                        {
                            <option value="@voucher.Code">@voucher.Code - Giảm @voucher.Value:0%</option>
                        }
                    </select>
                </div>
                <div>
                    <label asp-for="FreeShipVoucherCode" class="block text-sm font-semibold mb-1">Chọn voucher freeship</label>
                    <select asp-for="FreeShipVoucherCode" class="w-full rounded-xl border px-3 py-2">
                        <option value="">Không dùng voucher freeship</option>
                        @foreach (var voucher in freeShipVouchers)
                        {
                            <option value="@voucher.Code">@voucher.Code - Freeship</option>
                        }
                    </select>
                </div>
            </div>
        }

        <div class="grid md:grid-cols-2 gap-4">
            <input asp-for="ManualDistanceKm" type="number" step="0.1" placeholder="Khoảng cách dự phòng (km)" class="rounded-xl border px-3 py-2" />
            <label class="flex items-center gap-2">
                <input asp-for="SimulatePaid" />
                <span>Nhấn để mô phỏng đã thanh toán</span>
            </label>
        </div>

        <button class="px-6 py-3 bg-primary text-white rounded-xl font-semibold">Xác nhận đặt hàng</button>
    </form>
    <p class="text-sm text-slate-500 mt-4">Google Maps API key cấu hình tại appsettings.json > GoogleMaps:ApiKey. Nếu chưa có key, hệ thống dùng khoảng cách dự phòng bạn nhập.</p>
</section>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

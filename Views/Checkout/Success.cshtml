@model FlashFood.Web.Models.Entities.Order
@{
    ViewData["Title"] = "Đặt hàng thành công";
}
<section class="max-w-3xl mx-auto px-4 md:px-10 py-10 text-center">
    <h1 class="text-3xl font-black @(Model.IsPaid ? "text-green-700" : "text-amber-600")">
        @(Model.IsPaid ? "Thanh toán thành công" : "Đơn hàng đang chờ thanh toán")
    </h1>
    <p class="mt-3">Mã đơn: <strong>@Model.OrderCode</strong></p>
    <p>Tổng tiền: <strong>@Model.TotalAmount.ToString("N0")đ</strong></p>
    <p class="mt-2 text-slate-600">
        @(Model.IsPaid
            ? "Đơn hàng đã được ghi nhận và đang chờ cửa hàng xác nhận."
            : "Bạn có thể quay lại thanh toán VNPAY bất cứ lúc nào từ trang chi tiết đơn hàng.")
    </p>

    <div class="mt-6 flex flex-wrap justify-center gap-3">
        @if (User.Identity?.IsAuthenticated != true)
        {
            <a asp-controller="Checkout" asp-action="GuestOrders" class="inline-block px-6 py-3 bg-slate-900 text-white rounded-xl">Theo dõi đơn hàng</a>
        }
        @if (!Model.IsPaid)
        {
            <a asp-controller="Checkout" asp-action="ContinuePayment" asp-route-id="@Model.Id" class="inline-block px-6 py-3 bg-amber-500 text-white rounded-xl">Thanh toán lại</a>
        }
        <a asp-controller="Products" asp-action="Index" class="inline-block px-6 py-3 bg-primary text-white rounded-xl">Tiếp tục mua</a>
    </div>
</section>

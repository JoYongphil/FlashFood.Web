@model IEnumerable<FlashFood.Web.Models.Entities.Order>
@using FlashFood.Web.Models.Enums
@{
    ViewData["Title"] = "Theo dõi đơn hàng";

    string GetStatusLabel(OrderStatus status) => status switch
    {
        OrderStatus.PendingConfirmation => "Chờ xác nhận",
        OrderStatus.Preparing => "Đang làm",
        OrderStatus.Delivering => "Đang giao",
        OrderStatus.Delivered => "Đã giao",
        OrderStatus.Completed => "Hoàn thành",
        OrderStatus.Cancelled => "Hủy đơn",
        _ => status.ToString()
    };
}
<section class="max-w-5xl mx-auto px-4 md:px-10 py-8">
    <h1 class="text-3xl font-black mb-6">Theo dõi đơn hàng</h1>

    @if (!Model.Any())
    {
        <div class="bg-white border rounded-2xl p-4 text-slate-500">Không có đơn hàng nào trong phiên hiện tại. Khi đóng trình duyệt, danh sách theo dõi sẽ mất.</div>
    }
    else
    {
        <div class="space-y-4">
            @foreach (var order in Model)
            {
                <a asp-action="GuestOrderDetails" asp-route-id="@order.Id" class="block bg-white border rounded-2xl p-4 hover:border-primary">
                    <div class="flex flex-wrap justify-between gap-3">
                        <div>
                            <p class="font-bold">@order.OrderCode</p>
                            <p class="text-sm text-slate-500">@order.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                        <div class="text-right">
                            <p class="font-semibold">@order.TotalAmount.ToString("N0")đ</p>
                            <p class="text-sm">@GetStatusLabel(order.Status)</p>
                        </div>
                    </div>
                </a>
            }
        </div>
    }
</section>

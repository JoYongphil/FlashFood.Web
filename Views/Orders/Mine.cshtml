@model IEnumerable<FlashFood.Web.Models.Entities.Order>
@using FlashFood.Web.Models.Enums
@{
    ViewData["Title"] = "Đơn hàng của tôi";

    var activeOrders = Model
        .Where(x => x.Status != OrderStatus.Completed && x.Status != OrderStatus.Cancelled)
        .OrderByDescending(x => x.CreatedAt)
        .ToList();

    var historyOrders = Model
        .Where(x => x.Status == OrderStatus.Completed || x.Status == OrderStatus.Cancelled)
        .OrderByDescending(x => x.CreatedAt)
        .ToList();

    string GetStatusLabel(OrderStatus status) => status switch
    {
        OrderStatus.PendingConfirmation => "Chờ xác nhận",
        OrderStatus.Preparing => "Đang làm",
        OrderStatus.Delivering => "Đang giao",
        OrderStatus.Delivered => "Đã giao",
        OrderStatus.Completed => "Hoàn thành",
        OrderStatus.Cancelled => "Hủy đơn",
        _ => status.ToString()
    };
}
<section class="max-w-7xl mx-auto px-4 md:px-10 py-8">
    <h1 class="text-3xl font-black mb-6">Đơn hàng của tôi</h1>

    <div class="mb-10">
        <h2 class="text-2xl font-bold mb-4">Đơn đang xử lý</h2>
        <div class="space-y-4">
            @if (!activeOrders.Any())
            {
                <div class="bg-white border rounded-2xl p-4 text-slate-500">Bạn chưa có đơn hàng đang xử lý.</div>
            }
            else
            {
                @foreach (var order in activeOrders)
                {
                    <div class="bg-white border rounded-2xl p-4">
                        <div class="flex flex-wrap justify-between gap-3">
                            <div>
                                <p class="font-bold">@order.OrderCode</p>
                                <p class="text-sm text-slate-500">@order.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                            </div>
                            <div class="text-right">
                                <p class="font-semibold">@order.TotalAmount.ToString("N0")đ</p>
                                <p class="text-sm">@GetStatusLabel(order.Status)</p>
                            </div>
                        </div>
                        <div class="mt-4 flex gap-2 flex-wrap">
                            <a asp-action="Details" asp-route-id="@order.Id" class="px-3 py-2 rounded-xl bg-slate-100">Chi tiết</a>
                            <a asp-action="Invoice" asp-route-id="@order.Id" class="px-3 py-2 rounded-xl bg-slate-100">PDF hóa đơn</a>
                            @if (order.Status == OrderStatus.PendingConfirmation)
                            {
                                <form asp-action="Cancel" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@order.Id" />
                                    <button class="px-3 py-2 rounded-xl bg-red-100 text-red-700">Hủy đơn</button>
                                </form>
                            }
                            @if (order.Status == OrderStatus.Delivered)
                            {
                                <form asp-action="ConfirmReceived" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@order.Id" />
                                    <button class="px-3 py-2 rounded-xl bg-green-100 text-green-700">Đã nhận hàng</button>
                                </form>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <div>
        <h2 class="text-2xl font-bold mb-4">Lịch sử đơn hàng</h2>
        <div class="space-y-4">
            @if (!historyOrders.Any())
            {
                <div class="bg-white border rounded-2xl p-4 text-slate-500">Chưa có đơn nào trong lịch sử.</div>
            }
            else
            {
                @foreach (var order in historyOrders)
                {
                    <div class="bg-white border rounded-2xl p-4">
                        <div class="flex flex-wrap justify-between gap-3">
                            <div>
                                <p class="font-bold">@order.OrderCode</p>
                                <p class="text-sm text-slate-500">@order.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                            </div>
                            <div class="text-right">
                                <p class="font-semibold">@order.TotalAmount.ToString("N0")đ</p>
                                <p class="text-sm">@GetStatusLabel(order.Status)</p>
                            </div>
                        </div>
                        <div class="mt-4 flex gap-2 flex-wrap">
                            <a asp-action="Details" asp-route-id="@order.Id" class="px-3 py-2 rounded-xl bg-slate-100">Chi tiết</a>
                            <a asp-action="Invoice" asp-route-id="@order.Id" class="px-3 py-2 rounded-xl bg-slate-100">PDF hóa đơn</a>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

@model FlashFood.Web.Models.Entities.Order
@using FlashFood.Web.Models.Enums
@{
    ViewData["Title"] = "Chi tiết đơn";

    string GetStatusLabel(OrderStatus status) => status switch
    {
        OrderStatus.PendingPayment => "Chờ thanh toán",
        OrderStatus.PendingConfirmation => "Chờ xác nhận",
        OrderStatus.Preparing => "Đang làm",
        OrderStatus.Delivering => "Đang giao",
        OrderStatus.Delivered => "Đã giao",
        OrderStatus.Completed => "Hoàn thành",
        OrderStatus.Cancelled => "Hủy đơn",
        _ => status.ToString()
    };
}
<section class="max-w-7xl mx-auto px-4 md:px-10 py-8">
    <h1 class="text-3xl font-black mb-2">Chi tiết đơn @Model.OrderCode</h1>
    <p class="text-slate-500 mb-6">Đặt lúc: @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>

    <div class="grid lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 space-y-4">
            @foreach (var item in Model.Items)
            {
                var imageUrl = item.Product?.ImageUrl;
                if (string.IsNullOrWhiteSpace(imageUrl))
                {
                    imageUrl = "https://via.placeholder.com/96x96?text=Food";
                }

                <div class="bg-white border rounded-2xl p-4 flex gap-4 items-center">
                    <img src="@imageUrl" alt="@item.ProductNameSnapshot" class="w-24 h-24 rounded-xl object-cover" />
                    <div class="flex-1">
                        <h3 class="font-bold">@item.ProductNameSnapshot</h3>
                        @if (!string.IsNullOrWhiteSpace(item.VariantNameSnapshot))
                        {
                            <p class="text-sm text-slate-500">Biến thể: @item.VariantNameSnapshot</p>
                        }
                        <p class="text-primary font-semibold">@item.UnitPrice.ToString("N0")đ</p>
                    </div>
                    <div class="text-right">
                        <p class="text-sm text-slate-500">Số lượng: @item.Quantity</p>
                        <p class="font-bold">@item.LineTotal.ToString("N0")đ</p>
                    </div>
                </div>
            }
        </div>

        <div class="bg-white border rounded-2xl p-4 h-fit space-y-3">
            <h3 class="font-bold text-lg">Tóm tắt đơn</h3>
            <div class="flex justify-between"><span>Trạng thái</span><strong>@GetStatusLabel(Model.Status)</strong></div>
            <div class="flex justify-between"><span>Thanh toán</span><strong>@(Model.IsPaid ? "Đã thanh toán" : "Chưa thanh toán")</strong></div>
            <div class="flex justify-between"><span>Tạm tính</span><strong>@Model.Subtotal.ToString("N0")đ</strong></div>
            <div class="flex justify-between"><span>Giảm giá</span><strong>-@Model.DiscountAmount.ToString("N0")đ</strong></div>
            <div class="flex justify-between"><span>Phí ship</span><strong>@Model.ShippingFee.ToString("N0")đ</strong></div>
            <div class="flex justify-between text-lg pt-2 border-t"><span class="font-bold">Tổng cộng</span><strong>@Model.TotalAmount.ToString("N0")đ</strong></div>

            <div class="pt-3 border-t space-y-1 text-sm text-slate-600">
                <p><span class="font-semibold text-slate-800">Người nhận:</span> @Model.CustomerName - @Model.Phone</p>
                <p><span class="font-semibold text-slate-800">Địa chỉ:</span> @Model.AddressDetail, @Model.Ward, @Model.District, @Model.Province</p>
            </div>

            @if (!Model.IsPaid && Model.Status != OrderStatus.Cancelled && Model.Status != OrderStatus.Completed)
            {
                <a asp-controller="Checkout" asp-action="ContinuePayment" asp-route-id="@Model.Id" class="block mt-3 text-center py-3 bg-amber-500 hover:bg-amber-600 text-white rounded-xl font-semibold">Thanh toán lại</a>
            }
            <a asp-action="Invoice" asp-route-id="@Model.Id" class="block mt-3 text-center py-3 bg-slate-100 hover:bg-slate-200 rounded-xl font-semibold">Tải PDF hóa đơn</a>
        </div>
    </div>
</section>

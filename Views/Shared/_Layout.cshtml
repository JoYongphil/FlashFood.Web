@using FlashFood.Web.Services
@using Microsoft.AspNetCore.Http
@inject ICartService CartService
@{
    var cartCount = CartService.GetItems().Sum(x => x.Quantity);
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var currentArea = ViewContext.RouteData.Values["area"]?.ToString() ?? string.Empty;
    var isAdmin = User.IsInRole("Admin");

    var guestOrderJson = Context.Session.GetString("FLASHFOOD_GUEST_ORDER_IDS");
    var hasGuestOrders = !string.IsNullOrWhiteSpace(guestOrderJson) && guestOrderJson != "[]";

    var showBackToHome = !isAdmin
        && !(string.Equals(currentController, "Products", StringComparison.OrdinalIgnoreCase)
             && string.Equals(currentAction, "Index", StringComparison.OrdinalIgnoreCase)
             && string.IsNullOrWhiteSpace(currentArea));
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Flash Food</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#f20d0d',
                        secondary: '#ffc107',
                        backgroundLight: '#f8f5f5',
                        backgroundDark: '#221010'
                    },
                    fontFamily: {
                        display: ['Plus Jakarta Sans', 'sans-serif']
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: "Plus Jakarta Sans", sans-serif; }
    </style>
    <script>
        function ffGoBack(fallbackUrl) {
            if (window.history.length <= 1) {
                window.location.href = fallbackUrl;
                return false;
            }

            const currentPath = window.location.pathname + window.location.search;

            try {
                if (document.referrer) {
                    const ref = new URL(document.referrer);
                    const refPath = ref.pathname + ref.search;

                    // Skip duplicate PRG entries (POST -> Redirect -> same URL)
                    if (ref.origin === window.location.origin && refPath === currentPath && window.history.length > 2) {
                        window.history.go(-2);
                        return false;
                    }
                }
            } catch (e) {
                // no-op
            }

            window.history.back();
            return false;
        }
    </script>
</head>
<body class="bg-backgroundLight text-slate-900 min-h-screen flex flex-col">
<header class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-primary/10 px-4 md:px-10 py-3">
    <div class="max-w-7xl mx-auto flex items-center justify-between gap-4">
        @if (isAdmin)
        {
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="flex items-center gap-2 text-primary">
                <span class="material-symbols-outlined text-4xl">bolt</span>
                <h2 class="text-slate-900 text-xl font-extrabold tracking-tight">Flash Food</h2>
            </a>
        }
        else
        {
            <a asp-controller="Products" asp-action="Index" class="flex items-center gap-2 text-primary">
                <span class="material-symbols-outlined text-4xl">bolt</span>
                <h2 class="text-slate-900 text-xl font-extrabold tracking-tight">Flash Food</h2>
            </a>
        }

        <div class="flex items-center gap-3">
            @if (!isAdmin)
            {
                <a asp-controller="Cart" asp-action="Index" class="relative p-2 rounded-xl bg-primary/10 text-primary hover:bg-primary hover:text-white transition-colors" title="Giỏ hàng">
                    <span class="material-symbols-outlined">shopping_cart</span>
                    <span class="absolute -top-1 -right-1 bg-primary text-white text-xs rounded-full px-1.5">@cartCount</span>
                </a>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Orders" asp-action="Mine" class="p-2 rounded-xl bg-slate-100 text-slate-700 hover:bg-slate-200 transition-colors" title="Trạng thái đơn">
                        <span class="material-symbols-outlined">receipt_long</span>
                    </a>
                }
                else if (hasGuestOrders)
                {
                    <a asp-controller="Checkout" asp-action="GuestOrders" class="p-2 rounded-xl bg-slate-100 text-slate-700 hover:bg-slate-200 transition-colors" title="Trạng thái đơn">
                        <span class="material-symbols-outlined">receipt_long</span>
                    </a>
                }
            }
            <partial name="_LoginPartial" />
        </div>
    </div>
</header>
<main class="flex-1">
    <div class="max-w-7xl mx-auto px-4 md:px-10 py-4">
        @if (showBackToHome)
        {
            <a href="#" onclick="return ffGoBack('@Url.Action("Index", "Products")');" class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-slate-100 hover:bg-slate-200 font-semibold mb-4" title="Quay lại trang trước">
                <span class="material-symbols-outlined">arrow_back</span>
            </a>
        }

        @if (TempData["Success"] is string success)
        {
            <div class="mb-4 rounded-lg bg-green-100 text-green-700 px-4 py-3">@success</div>
        }
        @if (TempData["Error"] is string error)
        {
            <div class="mb-4 rounded-lg bg-red-100 text-red-700 px-4 py-3">@error</div>
        }
    </div>
    @RenderBody()
</main>
<footer class="bg-slate-900 text-slate-400 py-10 px-4 md:px-10 mt-12">
    <div class="max-w-7xl mx-auto text-sm">© 2026 Flash Food. Đồ án ASP.NET Core MVC.</div>
</footer>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@model ErrorViewModel
@{
    ViewData["Title"] = "Lỗi";
}
<section class="max-w-4xl mx-auto px-4 md:px-10 py-10">
    <h1 class="text-3xl font-black text-red-600">Đã xảy ra lỗi</h1>
    <p class="mt-3">Hệ thống gặp lỗi khi xử lý yêu cầu của bạn.</p>

    @if (Model.ShowRequestId)
    {
        <p class="mt-2"><strong>Mã yêu cầu:</strong> <code>@Model.RequestId</code></p>
    }
</section>

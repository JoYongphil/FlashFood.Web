@model IEnumerable<FlashFood.Web.Models.Entities.Order>
@using FlashFood.Web.Models.Enums
@{
    ViewData["Title"] = "Quản lý đơn";

    var currentOrderCode = (ViewBag.OrderCode as string) ?? string.Empty;
    var currentFromDateTime = (ViewBag.FromDateTime as string) ?? string.Empty;
    var currentToDateTime = (ViewBag.ToDateTime as string) ?? string.Empty;
    var currentSort = (ViewBag.AmountSort as string) ?? string.Empty;

    string GetStatusLabel(OrderStatus status) => status switch
    {
        OrderStatus.PendingPayment => "Chờ thanh toán",
        OrderStatus.PendingConfirmation => "Chờ xác nhận",
        OrderStatus.Preparing => "Đang làm",
        OrderStatus.Delivering => "Đang giao",
        OrderStatus.Delivered => "Đã giao",
        OrderStatus.Completed => "Hoàn thành",
        OrderStatus.Cancelled => "Hủy đơn",
        _ => status.ToString()
    };
}
<section class="max-w-7xl mx-auto px-4 md:px-10 py-8">
    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-100 hover:bg-slate-200 text-sm font-semibold mb-4">
        <span class="material-symbols-outlined">arrow_back</span>
        Về màn hình quản trị
    </a>

    <h1 class="text-3xl font-black mb-6">Quản lý đơn hàng</h1>

    <form method="get" asp-area="Admin" asp-controller="Orders" asp-action="Index" class="bg-white border rounded-xl p-4 mb-6 grid grid-cols-1 md:grid-cols-5 gap-3">
        <div>
            <label class="block text-sm font-semibold mb-1">Mã đơn</label>
            <input type="text" name="orderCode" value="@currentOrderCode" placeholder="VD: FF2026..." class="w-full rounded-xl border px-3 py-2" />
        </div>

        <div>
            <label class="block text-sm font-semibold mb-1">Từ thời gian</label>
            <input type="datetime-local" name="fromDateTime" value="@currentFromDateTime" class="w-full rounded-xl border px-3 py-2" />
        </div>

        <div>
            <label class="block text-sm font-semibold mb-1">Đến thời gian</label>
            <input type="datetime-local" name="toDateTime" value="@currentToDateTime" class="w-full rounded-xl border px-3 py-2" />
        </div>

        <div>
            <label class="block text-sm font-semibold mb-1">Sắp xếp giá trị đơn</label>
            <select name="amountSort" class="w-full rounded-xl border px-3 py-2">
                <option value="" selected="@(string.IsNullOrWhiteSpace(currentSort))">Mặc định (mới nhất)</option>
                <option value="asc" selected="@(currentSort == "asc")">Tăng dần</option>
                <option value="desc" selected="@(currentSort == "desc")">Giảm dần</option>
            </select>
        </div>

        <div class="flex items-end gap-2">
            <button type="submit" class="px-4 py-2 rounded-xl bg-primary text-white font-semibold">Tìm kiếm</button>
            <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="px-4 py-2 rounded-xl bg-slate-100 hover:bg-slate-200 font-semibold">Đặt lại</a>
        </div>
    </form>

    <div class="space-y-3">
        @if (!Model.Any())
        {
            <div class="bg-white border rounded-xl p-4 text-slate-500">Không tìm thấy hóa đơn phù hợp.</div>
        }
        else
        {
            @foreach (var order in Model)
            {
                <a asp-area="Admin" asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id" class="block bg-white border rounded-xl p-3 hover:border-primary">
                    <div class="flex justify-between gap-4">
                        <div>
                            <strong>@order.OrderCode</strong>
                            <p class="text-sm text-slate-500">@order.CustomerName - @order.Phone</p>
                            <p class="text-xs text-slate-400">Đặt lúc: @order.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                        <div class="text-right">
                            <p class="font-semibold">@order.TotalAmount.ToString("N0")đ</p>
                            <p class="text-sm">@GetStatusLabel(order.Status)</p>
                        </div>
                    </div>
                </a>
            }
        }
    </div>
</section>

@model FlashFood.Web.Models.Entities.Order
@using FlashFood.Web.Models.Enums
@{
    ViewData["Title"] = "Chi tiết đơn";

    string GetStatusLabel(OrderStatus status) => status switch
    {
        OrderStatus.PendingConfirmation => "Chờ xác nhận",
        OrderStatus.Preparing => "Đang làm",
        OrderStatus.Delivering => "Đang giao",
        OrderStatus.Delivered => "Đã giao",
        OrderStatus.Completed => "Hoàn thành",
        OrderStatus.Cancelled => "Hủy đơn",
        _ => status.ToString()
    };
}
<section class="max-w-5xl mx-auto px-4 md:px-10 py-8">
    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-100 hover:bg-slate-200 text-sm font-semibold mb-4">
        <span class="material-symbols-outlined">arrow_back</span>
        Về màn hình quản trị
    </a>

    <h1 class="text-3xl font-black mb-4">Hóa đơn @Model.OrderCode</h1>
    <p>Khách: @Model.CustomerName - @Model.Phone - @Model.Email</p>
    <p>Địa chỉ: @Model.AddressDetail, @Model.Ward, @Model.District, @Model.Province</p>
    <p>Ngày giờ đặt: @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
    <p>Khoảng cách: @Model.DistanceKm km</p>
    <p>Trạng thái hiện tại: <strong>@GetStatusLabel(Model.Status)</strong></p>

    <form asp-area="Admin" asp-controller="Orders" asp-action="UpdateStatus" method="post" class="my-4 flex gap-2 items-center">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />
        <select name="status" class="rounded-xl border px-3 py-2" asp-items="ViewBag.Statuses"></select>
        <button class="px-4 py-2 rounded-xl bg-primary text-white">Cập nhật trạng thái</button>
    </form>

    <h2 class="text-xl font-bold mt-6 mb-3">Danh sách món trong hóa đơn</h2>
    <div class="space-y-3">
        @foreach (var item in Model.Items)
        {
            <div class="bg-white border rounded-xl p-3 flex justify-between items-center">
                <div>
                    <p class="font-semibold">@item.ProductNameSnapshot @(string.IsNullOrWhiteSpace(item.VariantNameSnapshot) ? "" : $"({item.VariantNameSnapshot})")</p>
                    <p class="text-sm text-slate-500">Đơn giá: @item.UnitPrice.ToString("N0")đ - Số lượng: @item.Quantity</p>
                </div>
                <strong>@item.LineTotal.ToString("N0")đ</strong>
            </div>
        }
    </div>

    <div class="mt-6 bg-white border rounded-xl p-4 space-y-2">
        <div class="flex justify-between"><span>Tạm tính</span><strong>@Model.Subtotal.ToString("N0")đ</strong></div>
        <div class="flex justify-between"><span>Giảm giá</span><strong>-@Model.DiscountAmount.ToString("N0")đ</strong></div>
        <div class="flex justify-between"><span>Phí ship</span><strong>@Model.ShippingFee.ToString("N0")đ</strong></div>
        <div class="flex justify-between text-lg"><span class="font-bold">Tổng cộng</span><strong>@Model.TotalAmount.ToString("N0")đ</strong></div>
    </div>
</section>

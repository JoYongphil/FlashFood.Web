@page
@model ForgotPasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Quên mật khẩu";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Flash Food</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#f20d0d",
                        backgroundLight: "#f8f5f5",
                        backgroundDark: "#221010"
                    },
                    fontFamily: {
                        display: ["Plus Jakarta Sans", "sans-serif"]
                    }
                }
            }
        };
    </script>
    <style>
        body { font-family: "Plus Jakarta Sans", sans-serif; }
    </style>
</head>
<body class="bg-backgroundLight text-slate-900 min-h-screen font-display antialiased">
    <div class="flex min-h-screen w-full">
        <div class="hidden lg:flex lg:w-1/2 relative overflow-hidden">
            <div class="absolute inset-0 bg-primary/10 mix-blend-multiply z-10"></div>
            <img class="absolute inset-0 h-full w-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCxxg-4wYMQ9e_MYq-039iCVczcaS33L-t11nmlIZyn9nL9_x6xPrc50t9LUQSbtNwxG6_FgsaJXxehcHxVz34cN-iDZOSRdTVBLZX5LRDrS_i6TU1nL6P54oysFvTUfl8I-t00tMfA9yL6Y_33tlffi_Q4SZh17rGXIhuwBgnyStl2PPC5etKadJh73MvGANRVCbfJIl3EF6-xgPviw5-Rvanmq722qJ5-mM24FW8vcjzXxzs2tJws5A4hogvzzxNUetaVaIn398QH" alt="Flash Food" />
            <div class="absolute bottom-12 left-12 z-20 text-white">
                <div class="flex items-center gap-2 mb-4">
                    <span class="material-symbols-outlined text-4xl text-primary bg-white rounded-full p-2">fastfood</span>
                    <h1 class="text-3xl font-extrabold tracking-tight">Flash Food</h1>
                </div>
                <p class="text-xl font-medium opacity-90">Giao hàng cực nhanh, đồ ăn cực nóng.</p>
            </div>
        </div>

        <div class="flex flex-col w-full lg:w-1/2 bg-white">
            <header class="flex items-center justify-end px-6 py-6 lg:px-12">
                <a asp-page="./Login" class="flex h-10 w-10 items-center justify-center rounded-full bg-slate-100 text-slate-900 hover:bg-slate-200 transition-colors">
                    <span class="material-symbols-outlined">arrow_back</span>
                </a>
            </header>

            <div class="flex flex-1 flex-col justify-center px-6 py-12 lg:px-24">
                <div class="max-w-md w-full mx-auto">
                    <div class="mb-10">
                        <h2 class="text-slate-900 text-4xl font-black leading-tight tracking-tight mb-3">Quên mật khẩu</h2>
                        <p class="text-slate-500 text-base">Đừng lo lắng! Nhập email của bạn và chúng tôi sẽ giúp bạn đặt lại mật khẩu.</p>
                    </div>

                    <form method="post" class="space-y-6">
                        <div asp-validation-summary="ModelOnly" class="rounded-xl bg-red-100 text-red-700 px-4 py-3 text-sm" role="alert"></div>
                        <div class="flex flex-col gap-2">
                            <label asp-for="Input.Email" class="text-slate-900 text-sm font-semibold">Email</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">mail</span>
                                <input asp-for="Input.Email" autocomplete="username" aria-required="true" placeholder="name@example.com" class="w-full rounded-lg border border-slate-200 bg-white h-14 pl-12 pr-4 text-base transition-all placeholder:text-slate-400 focus:ring-2 focus:ring-primary focus:border-transparent" />
                            </div>
                            <span asp-validation-for="Input.Email" class="text-red-600 text-sm"></span>
                        </div>

                        <button type="submit" class="w-full flex items-center justify-center rounded-lg h-14 px-5 bg-primary hover:bg-primary/90 text-white text-base font-bold transition-all shadow-lg shadow-primary/20">
                            Đặt lại mật khẩu
                        </button>
                    </form>

                    <div class="mt-8 text-center">
                        <p class="text-slate-500 text-sm">
                            Bạn đã nhớ lại mật khẩu?
                            <a asp-page="./Login" class="text-primary font-bold hover:underline ml-1">Quay lại đăng nhập</a>
                        </p>
                    </div>
                </div>
            </div>

            <footer class="px-12 py-8 text-center lg:text-left">
                <p class="text-slate-400 text-xs">© 2026 Flash Food. Mọi quyền được bảo lưu.</p>
            </footer>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>

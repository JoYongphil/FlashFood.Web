@page
@model ResetPasswordConfirmationModel
@{
    Layout = null;
    ViewData["Title"] = "Xác nhận đặt lại mật khẩu";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Flash Food</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#f20d0d",
                        backgroundLight: "#f8f5f5",
                        backgroundDark: "#221010"
                    },
                    fontFamily: {
                        display: ["Plus Jakarta Sans", "sans-serif"]
                    }
                }
            }
        };
    </script>
    <style>
        body { font-family: "Plus Jakarta Sans", sans-serif; }
    </style>
</head>
<body class="font-display bg-backgroundLight text-slate-900 antialiased">
    <div class="flex min-h-screen">
        <div class="hidden lg:flex lg:w-1/2 relative overflow-hidden bg-primary/10">
            <div class="absolute inset-0 z-10 bg-gradient-to-t from-slate-900/80 to-transparent"></div>
            <div class="absolute inset-0 flex flex-col justify-end p-12 z-20">
                <div class="flex items-center gap-2 mb-4">
                    <span class="material-symbols-outlined text-primary text-4xl">restaurant</span>
                    <h1 class="text-3xl font-extrabold tracking-tight text-white">Flash Food</h1>
                </div>
                <p class="text-white/90 text-lg max-w-md">Giao hàng nhanh chóng, món ăn nóng hổi ngay tại cửa nhà bạn.</p>
            </div>
            <div class="h-full w-full bg-center bg-cover" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuC895D9CqCRhghNjNwGXppCBXSNc-iFbS08ZH1wmPKsOY7Y3Nfhd0cP3ZRl9BSKsDAfi83TMJaZ4rUn8wsQVNQ9KEqDhdhCfyN08oCyefPokh_IiJS-Dqx94yZ_kNMvr1YJAdeUf06X1zTAo4qbo2CrVBct_j4iJs7bSnXr6TKdbkg4A_nZ-OL-Dgb1lkzI0sZf64qIyWXqatoZV1eD7BCWizXjRkI4wfa1VjZmJvppYWu7Voi3rMRlRuXKYq5mBhiJtzjt7SaecNWI');"></div>
        </div>

        <div class="w-full lg:w-1/2 flex flex-col justify-center items-center p-6 sm:p-12 md:p-24 bg-white">
            <div class="max-w-md w-full">
                <div class="flex items-center gap-2 mb-12 lg:hidden">
                    <span class="material-symbols-outlined text-primary text-3xl">restaurant</span>
                    <h2 class="text-2xl font-bold tracking-tight">Flash Food</h2>
                </div>

                <div class="mb-8 flex h-16 w-16 items-center justify-center rounded-full bg-green-100">
                    <span class="material-symbols-outlined text-green-600 text-3xl">check_circle</span>
                </div>

                <header class="mb-8">
                    <h2 class="text-3xl font-black leading-tight tracking-tight text-slate-900 mb-4">Xác nhận đặt lại mật khẩu</h2>
                    <p class="text-slate-600 text-base leading-relaxed">
                        Mật khẩu đã được cập nhật thành công. Bây giờ bạn có thể dùng mật khẩu mới để đăng nhập vào tài khoản.
                    </p>
                </header>

                <div class="space-y-6">
<a asp-page="./Login" class="flex w-full items-center justify-center gap-2 rounded-lg bg-primary px-4 py-3 text-sm font-bold text-white transition-colors hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:ring-offset-2">
                        <span>Đến trang đăng nhập</span>
                        <span class="material-symbols-outlined text-sm">arrow_forward</span>
                    </a>

                    <div class="pt-8 border-t border-slate-100">
                        <p class="text-xs text-slate-500 text-center">© 2026 Flash Food. Mọi quyền được bảo lưu.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>



@page
@model ConfirmEmailModel
@{
    ViewData["Title"] = "Xac nhan email";
    var isSuccess = string.Equals(Model.StatusMessage, "Xac nhan email thanh cong. Ban da co the dang nhap.", System.StringComparison.Ordinal);
}

<section class="max-w-2xl mx-auto px-4 py-16">
    <div class="bg-white border rounded-2xl p-8 text-center">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full @(isSuccess ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700")">
            <span class="material-symbols-outlined text-4xl">@(isSuccess ? "verified" : "error")</span>
        </div>

        <h1 class="mt-5 text-3xl font-black text-slate-900">@ViewData["Title"]</h1>
        <p class="mt-4 text-slate-600">@Model.StatusMessage</p>
        <p class="mt-3 text-sm text-slate-500">
            @(isSuccess
                ? "Ban co the dang nhap ngay de tiep tuc dat mon va nhan uu dai cua Flash Food."
                : "Lien ket xac nhan co the da het han hoac khong hop le. Hay thu gui lai email xac nhan.")
        </p>

        <div class="mt-6 flex flex-wrap justify-center gap-3">
            <a asp-page="./Login" class="px-5 py-3 rounded-xl bg-slate-900 text-white font-semibold">Ve dang nhap</a>
            @if (!isSuccess)
            {
                <a asp-page="./ResendEmailConfirmation" class="px-5 py-3 rounded-xl bg-slate-100 text-slate-900 font-semibold">Gui lai email xac nhan</a>
            }
        </div>
    </div>
</section>
@page
@model ResetPasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Đặt lại mật khẩu";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Flash Food</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#f20d0d",
                        backgroundLight: "#f8f5f5",
                        backgroundDark: "#221010"
                    },
                    fontFamily: {
                        display: ["Plus Jakarta Sans", "sans-serif"]
                    }
                }
            }
        };
    </script>
    <style>
        body { font-family: "Plus Jakarta Sans", sans-serif; }
    </style>
</head>
<body class="bg-backgroundLight text-slate-900 min-h-screen flex items-center justify-center font-display">
    <div class="flex min-h-screen w-full flex-col lg:flex-row overflow-hidden">
        <div class="hidden lg:flex lg:w-1/2 relative bg-primary items-center justify-center overflow-hidden">
            <div class="absolute inset-0 opacity-20 bg-cover bg-center" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuA_1Ngm7dc2mIKjXMvqhG7YM2dLlctFTGHa-qAnmQUtC8ACrvcA60TEeHkT8SiYjDu1KYh3tvF0HZtubspSIoFPA3J7iShXAHWrnZ43kbieC7PI4fduExnwKwJG9SSiHTCioS8ZHYf0eq8qvIvK4bnzPo8jCjzKQvUhrc7O-W0ZYoasIwT-YWMWQUm7u6epIUzSiS2z9PNci7w1YC9lXa57XdqCME-dzLBvmfBPFQBRU74oQoLjXgZmjVi6lyFOPpESxLpxyYynNf66');"></div>
            <div class="relative z-10 text-center px-12">
                <div class="flex items-center justify-center gap-3 mb-6 text-white">
                    <span class="material-symbols-outlined text-5xl">restaurant</span>
                    <h1 class="text-4xl font-black tracking-tighter">Flash Food</h1>
                </div>
                <h2 class="text-white text-2xl font-bold mb-4">Đặt lại mật khẩu nhanh chóng.</h2>
                <p class="text-white/80 text-lg">Đổi mật khẩu mới để tiếp tục sử dụng tài khoản của bạn.</p>
            </div>
        </div>

        <div class="flex-1 flex flex-col justify-center items-center bg-backgroundLight p-8 lg:p-24">
            <div class="w-full max-w-md">
                <div class="lg:hidden flex items-center justify-center gap-2 mb-12 text-primary">
                    <span class="material-symbols-outlined text-4xl">restaurant</span>
                    <span class="text-2xl font-black tracking-tighter">Flash Food</span>
                </div>

                <header class="mb-10">
                    <h2 class="text-slate-900 text-3xl font-black leading-tight mb-2">Đặt lại mật khẩu</h2>
                    <p class="text-slate-500 text-base">Nhập mật khẩu mới cho tài khoản của bạn.</p>
                </header>

                <form method="post" class="space-y-6">
                    <div asp-validation-summary="ModelOnly" class="rounded-xl bg-red-100 text-red-700 px-4 py-3 text-sm" role="alert"></div>
                    <input asp-for="Input.Code" type="hidden" />

                    <div class="flex flex-col gap-2">
                        <label asp-for="Input.Email" class="text-slate-900 text-sm font-semibold">Email</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">mail</span>
                            <input asp-for="Input.Email" readonly class="block w-full pl-12 pr-4 py-4 rounded-xl border border-slate-200 bg-slate-100 text-slate-700" />
                        </div>
                        <span asp-validation-for="Input.Email" class="text-red-600 text-sm"></span>
                    </div>

                    <div class="flex flex-col gap-2">
                        <label asp-for="Input.Password" class="text-slate-900 text-sm font-semibold">Mật khẩu mới</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">lock</span>
                            <input id="reset-password" asp-for="Input.Password" type="password" autocomplete="new-password" aria-required="true" placeholder="Nhập mật khẩu mới" class="block w-full pl-12 pr-12 py-4 rounded-xl border border-slate-200 bg-white text-slate-900 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none" />
                            <button id="toggle-reset-password" type="button" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600" aria-label="Hiện mật khẩu mới">
                                <span id="toggle-reset-password-icon" class="material-symbols-outlined">visibility</span>
                            </button>
                        </div>
                        <span asp-validation-for="Input.Password" class="text-red-600 text-sm"></span>
                    </div>

                    <div class="flex flex-col gap-2">
                        <label asp-for="Input.ConfirmPassword" class="text-slate-900 text-sm font-semibold">Xác nhận mật khẩu</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl">lock_reset</span>
                            <input id="reset-confirm-password" asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" aria-required="true" placeholder="Nhập lại mật khẩu mới" class="block w-full pl-12 pr-12 py-4 rounded-xl border border-slate-200 bg-white text-slate-900 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none" />
                            <button id="toggle-reset-confirm-password" type="button" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600" aria-label="Hiện xác nhận mật khẩu">
                                <span id="toggle-reset-confirm-password-icon" class="material-symbols-outlined">visibility</span>
                            </button>
                        </div>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-red-600 text-sm"></span>
                    </div>

                    <button type="submit" class="w-full flex items-center justify-center h-14 bg-primary hover:bg-primary/90 text-white rounded-xl font-bold text-lg shadow-lg shadow-primary/20 transition-all active:scale-[0.98]">
                        Đặt lại mật khẩu
                    </button>
                </form>

                <div class="mt-10 text-center">
                    <a asp-page="./Login" class="text-slate-500 text-sm font-medium hover:text-primary transition-colors inline-flex items-center gap-1">
                        <span class="material-symbols-outlined text-sm">arrow_back</span>
                        Quay lại trang đăng nhập
                    </a>
                </div>

                <footer class="mt-20 text-slate-400 text-xs text-center">
                    © 2026 Flash Food. Mọi quyền được bảo lưu.
                </footer>
            </div>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            function bindToggle(inputId, buttonId, iconId, showLabel, hideLabel) {
                const input = document.getElementById(inputId);
                const button = document.getElementById(buttonId);
                const icon = document.getElementById(iconId);
                if (!input || !button || !icon) return;

                button.addEventListener("click", function () {
                    const hidden = input.type === "password";
                    input.type = hidden ? "text" : "password";
                    icon.textContent = hidden ? "visibility_off" : "visibility";
                    button.setAttribute("aria-label", hidden ? hideLabel : showLabel);
                });
            }

            bindToggle("reset-password", "toggle-reset-password", "toggle-reset-password-icon", "Hiện mật khẩu mới", "Ẩn mật khẩu mới");
            bindToggle("reset-confirm-password", "toggle-reset-confirm-password", "toggle-reset-confirm-password-icon", "Hiện xác nhận mật khẩu", "Ẩn xác nhận mật khẩu");
        })();
    </script>
</body>
</html>
